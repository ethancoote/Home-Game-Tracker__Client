---
import '../../styles/global.css';
const {href, text, id} = Astro.props;
---
{href ? 
    <a class="button" href={href}>{text}</a>
:
    <button class="button" id={id}>{text}</button>
}


<style>
    .button {
        display: flex;
        white-space: nowrap; 
        height: fit-content;
        width: fit-content;
        background-color: var(--white-200);
        border-radius: var(--border-radius);
        border: 1px solid var(--white-200);
        padding: 8px 16px;
        box-sizing: auto;
        text-decoration: none;
        color: var(--pri-900);
        font-size: 1rem;
        font-weight: 700;
        transition: .25s;
        font-family: inherit;

        &:hover {
            cursor: pointer;
            background-color: var(--white-100);
            color: var(--pri-400);
            box-shadow: 0px 3px 12px hsla(0, 0%, 100%, 0.3);
        }
    }
</style>
